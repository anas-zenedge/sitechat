{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "SiteChat": {
    "AppName": "SiteChat",
    "Environment": "development",
    "Debug": false,
    "SiteUrl": "http://localhost:8000",
    "Security": {
      "CorsOrigins": [
        "http://localhost:3000",
        "http://localhost:8000",
        "http://127.0.0.1:8000",
        "http://localhost:8015",
        "http://127.0.0.1:8015",
        "http://localhost:8012",
        "http://127.0.0.1:8012",
        "http://127.0.0.1",
        "http://localhost"
      ],
      "CorsAllowCredentials": true,
      "CorsOriginRegex": "^https?://127\\.0\\.0\\.1(?::\\d+)?$",
      "TrustedHosts": [ "localhost", "127.0.0.1" ],
      "TrustedProxyIps": [],
      "EnableSecurityHeaders": true,
      "ContentSecurityPolicy": ""
    },
    "MongoDb": {
      "Url": "mongodb://localhost:27017",
      "Database": "sitechat"
    },
    "Jwt": {
      "Secret": "CHANGE-THIS-SECRET-IN-PRODUCTION",
      "ExpireHours": 24
    },
    "PasswordPolicy": {
      "MinimumLength": 8,
      "RequireComplexity": true
    },
    "Rag": {
      "LlmProvider": "openrouter",
      "LlmModel": "openai/gpt-4o-mini",
      "EmbeddingModel": "openai/text-embedding-3-small",
      "OpenRouterBaseUrl": "https://openrouter.ai/api/v1",
      "OpenRouterApiKey": "",
      "OpenRouterReferer": "http://localhost:8000",
      "OpenRouterTitle": "SiteChat Backend",
      "Temperature": 0.7,
      "MaxTokens": 1000,
      "RetrievalK": 3
    },
    "Crawl": {
      "MaxPages": 100,
      "DelaySeconds": 1.0
    },
    "RateLimit": {
      "Requests": 20,
      "WindowSeconds": 60
    },
    "StaticFiles": {
      "FrontendRoot": ""
    }
  }
}
